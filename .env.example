# grafana-stack-templates — environment variables
#
# Copy to `.env` and fill in. The CLI reads only from the environment;
# no secret ever gets persisted to disk by `gst`.
#
#   cp .env.example .env
#   $EDITOR .env
#   set -a && source .env && set +a

# ──────────────────────────────────────────────────────────────────────────
# Required for any `gst install` of an alert-rule, dashboard, or
# slack-template module. Generate at:
#   <stack>.grafana.net → Administration → Users and access →
#   Service accounts → Add service account → Add token
# Scopes needed: alerts:write, metrics:read, folders:write
# Format: glsa_…
# ──────────────────────────────────────────────────────────────────────────
GRAFANA_URL=https://yourstack.grafana.net
GRAFANA_TOKEN=glsa_replace_me

# ──────────────────────────────────────────────────────────────────────────
# Required for any `gst install` of an sm-check module. Generate at:
#   <stack>.grafana.net → Synthetic Monitoring → Configuration →
#   Access tokens → Generate access token
# ──────────────────────────────────────────────────────────────────────────
SM_ACCESS_TOKEN=replace_me

# ──────────────────────────────────────────────────────────────────────────
# Required only when installing slack-templates/* and you want the CLI to
# also wire up a contact point in one go. If you already maintain the
# contact point yourself, leave this unset.
# Create at:  https://api.slack.com/messaging/webhooks
# Format: https://hooks.slack.com/services/T…/B…/…
# ──────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK=

# ──────────────────────────────────────────────────────────────────────────
# Manifest-gate toggles. Both default to off. Use them only in offline /
# air-gapped development. Never set in production deployments.
# ──────────────────────────────────────────────────────────────────────────
# GST_DISABLE_MANIFEST_CHECK=1
# GST_TOLERATE_MISSING_MANIFEST=1

# ──────────────────────────────────────────────────────────────────────────
# Convenience: equivalent to passing --dry-run on every `gst install` call.
# ──────────────────────────────────────────────────────────────────────────
# GST_DRY_RUN=1
